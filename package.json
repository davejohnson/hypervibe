{
  "name": "@davejohnson/hypervibe",
  "version": "0.1.3",
  "description": "MCP server for chat-driven infrastructure management",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davejohnson/hypervibe.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "infrastructure",
    "deploy",
    "railway",
    "cloud-run",
    "terraform",
    "agent"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hypervibe": "dist/index.js"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:tools": "node scripts/generate-tools-doc.mjs",
    "release:check": "npm test && npm run typecheck && npm run build && npm run prepublish-check",
    "release": "node scripts/release.mjs",
    "autofix": "node dist/agent/index.js",
    "prepublish-check": "bash scripts/prepublish-check.sh",
    "prepublishOnly": "npm run build && npm run prepublish-check"
  },
  "dependencies": {
    "@1password/sdk": "^0.4.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-ec2": "^3.1092.0",
    "@aws-sdk/client-rds": "^3.1092.0",
    "@bitwarden/sdk-napi": "^1.0.0",
    "@google-cloud/cloud-sql-connector": "1.10.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "google-auth-library": "^10.9.0",
    "graphql": "^16.9.0",
    "graphql-request": "^7.0.0",
    "pg": "^8.17.2",
    "sodium-native": "^4.0.0",
    "tldts": "^7.4.6",
    "tweetnacl": "^1.0.3",
    "tweetnacl-sealedbox-js": "^1.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist/",
    "data/.gitkeep"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
